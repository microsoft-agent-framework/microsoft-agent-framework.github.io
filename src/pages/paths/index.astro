---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PathHeader from '@/components/PathHeader.astro';
import { getLearningPaths } from '@/lib/tutorials';

const paths = await getLearningPaths();
const totalTutorials = paths.reduce((sum, p) => sum + p.tutorials.length, 0);

const PATH_COLORS = [
  'border-l-indigo-500 hover:bg-indigo-50/50',
  'border-l-violet-500 hover:bg-violet-50/50',
  'border-l-teal-600 hover:bg-teal-50/50',
  'border-l-amber-500 hover:bg-amber-50/50',
  'border-l-brand-500 hover:bg-brand-50/50',
  'border-l-rose-500 hover:bg-rose-50/50',
];
---

<BaseLayout title="Learning Paths" description="Curated, guided learning tracks for Agent Framework .NET.">
  <div class="mx-auto max-w-7xl px-4 pt-10 pb-14 sm:px-6 lg:px-8">
    <PathHeader
      eyebrow="Guided learning"
      title="Learning Paths"
      description="Choose a path, then work the tutorials in order. Each path is a curated, sequential journey from first concepts to production skills."
      stats={[
        { label: 'paths', value: paths.length },
        { label: 'total tutorials', value: totalTutorials }
      ]}
    />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {paths.map((path, i) => {
        const totalPathTime = path.tutorials.reduce((s, t) => s + (parseInt(t.time) || 0), 0);
        const accent = PATH_COLORS[i % PATH_COLORS.length];
        return (
          <a id={`path-card-${path.slug}`} class={`solid-card group flex flex-col overflow-hidden border-l-4 ${accent} bg-white/50 backdrop-blur-sm`} href={`/paths/${path.slug}`}>
            <div class="flex flex-1 flex-col p-6">
              <h2 class="text-xl font-900 group-hover:text-indigo-600 transition-colors duration-200">{path.title}</h2>
              <p class="mt-3 flex-1 text-sm leading-6 text-slate-500">{path.description}</p>
            </div>
            <div class="border-t border-border/40 px-6 py-4 flex items-center justify-between text-[10px] font-900 uppercase tracking-widest text-muted/70">
              <span class="flex items-center gap-1.5">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                {path.tutorials.length > 0 ? `${path.tutorials.length} Lessons` : 'Coming soon'}
              </span>
              {totalPathTime > 0 && (
                <span class="flex items-center gap-1.5">
                  <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {totalPathTime} min
                </span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
