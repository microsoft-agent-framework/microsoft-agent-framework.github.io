---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SampleCard from '@/components/SampleCard.astro';
import { getLearningPaths, getTutorials } from '@/lib/tutorials';

const tutorials = await getTutorials();
const paths = await getLearningPaths();
const startPath = paths.find((p) => p.slug === 'agent-essentials' && p.tutorials.length > 0) ?? paths.find((p) => p.tutorials.length > 0);
const firstLesson = startPath?.tutorials[0];

const totalTime = tutorials.reduce((sum, t) => {
  const mins = parseInt(t.time) || 0;
  return sum + mins;
}, 0);
const hours = Math.floor(totalTime / 60);
const featured = tutorials.slice(0, 6);

const PATH_COLORS = [
  'border-l-indigo-500 hover:bg-indigo-50/50',
  'border-l-violet-500 hover:bg-violet-50/50',
  'border-l-teal-600 hover:bg-teal-50/50',
  'border-l-amber-500 hover:bg-amber-50/50',
  'border-l-brand-500 hover:bg-brand-50/50',
  'border-l-rose-500 hover:bg-rose-50/50',
];

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<BaseLayout title="Agent Academy" description="Master the art of building AI agents through guided paths and hands-on tutorials.">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- ─── Title block ────────────────────────────────────────────── -->
    <div class="pt-24 pb-16 animate-fade-in relative overflow-hidden">
      <!-- Decorative Background Elements -->
      <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[500px] h-[500px] bg-indigo-500/5 rounded-full blur-[100px]"></div>
      
      <h1 class="heading-xl max-w-4xl text-gradient">
        Your Path to Mastering<br class="hidden sm:block" /> Microsoft Agent Framework.
      </h1>
      <p class="body-lg mt-8 max-w-2xl text-slate-500 font-500 leading-relaxed">
        Step-by-step .NET guides designed for developers. Start with Agent Essentials and progress through curated paths to master Advanced Orchestration and tool integration.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <div class="glass-card px-5 py-3 flex flex-col gap-0.5 min-w-[110px]">
          <span class="text-xs font-900 text-muted uppercase tracking-[0.15em]">{paths.length}</span>
          <span class="text-xl font-900 text-indigo-600">Paths</span>
        </div>
        <div class="glass-card px-5 py-3 flex flex-col gap-0.5 min-w-[110px]">
          <span class="text-xs font-900 text-muted uppercase tracking-[0.15em]">{tutorials.length}</span>
          <span class="text-xl font-900 text-indigo-600">Lessons</span>
        </div>
        {hours > 0 && (
          <div class="glass-card px-5 py-3 flex flex-col gap-0.5 min-w-[110px]">
            <span class="text-xs font-900 text-muted uppercase tracking-[0.15em]">{hours}+</span>
            <span class="text-xl font-900 text-indigo-600">Hours</span>
          </div>
        )}
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <a class="btn-primary px-10 py-4 text-base" href={firstLesson?.url ?? `${base}/paths`}>
          Start first lesson
          <svg class="size-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
        </a>
        <a class="btn-ghost px-10 py-4 text-base" href={`${base}/tutorials`}>Browse all</a>
      </div>
    </div>

    <!-- ─── Learning Paths ──────────────────────────────────────────── -->
    <section class="border-t border-border/60 pt-10 pb-12">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Learning paths</p>
          <h2 class="heading-lg mt-1.5">Pick a path, work the tutorials in order.</h2>
        </div>
        <a class="btn-ghost self-start sm:self-auto" href={`${base}/paths`}>All paths</a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {paths.map((path, i) => {
          const totalPathTime = path.tutorials.reduce((s, t) => s + (parseInt(t.time) || 0), 0);
          const accent = PATH_COLORS[i % PATH_COLORS.length];
          return (
            <a
              id={`home-path-${path.slug}`}
              class={`solid-card group flex flex-col overflow-hidden border-l-4 ${accent} bg-white/50 backdrop-blur-sm`}
              href={`${base}/paths/${path.slug}`}
            >
              <div class="flex flex-1 flex-col p-6">
                <h3 class="text-xl font-900 group-hover:text-indigo-600 transition-colors duration-200">{path.title}</h3>
                <p class="mt-3 flex-1 text-sm leading-6 text-slate-500">{path.description}</p>
              </div>
              <div class="border-t border-border/40 px-6 py-4 flex items-center justify-between text-[10px] font-900 uppercase tracking-widest text-muted/70">
                <span class="flex items-center gap-1.5">
                  <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                  {path.tutorials.length > 0 ? `${path.tutorials.length} Lessons` : 'Coming soon'}
                </span>
                {totalPathTime > 0 && (
                  <span class="flex items-center gap-1.5">
                    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {totalPathTime} min
                  </span>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ─── Tutorial Directory ──────────────────────────────────────── -->
    <section class="border-t border-border/60 pt-10 pb-14">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Tutorial directory</p>
          <h2 class="heading-lg mt-1.5">Latest tutorials</h2>
          <p class="body-sm mt-1.5 max-w-2xl">Jump into any tutorial directly. Each lesson is self-contained with objectives, prerequisites, and step-by-step instructions.</p>
        </div>
        <a class="btn-ghost self-start sm:self-auto" href={`${base}/tutorials`}>View all</a>
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {featured.map((tutorial) => <SampleCard tutorial={tutorial} />)}
      </div>
    </section>

  </div>
</BaseLayout>
