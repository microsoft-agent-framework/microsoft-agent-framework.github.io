---
interface Props {
  syncKey?: string;
}

const { syncKey } = Astro.props;
---
<custom-tabs class="block" data-sync-key={syncKey}>
  <div class="tabs-container my-6">
    <div class="tab-buttons flex border-b border-slate-200 overflow-x-auto scrollbar-hide" role="tablist">
    </div>
    <div class="tab-panels mt-4">
      <slot />
    </div>
  </div>
</custom-tabs>

<script>
  class TabsContainer extends HTMLElement {
    connectedCallback() {
      const syncKey = this.getAttribute('data-sync-key') || 'default';
      const storageKey = `preferred-tab-${syncKey}`;
      
      const panels = Array.from(this.querySelectorAll('.tab-panel'));
      const buttonContainer = this.querySelector('.tab-buttons');
      
      // Prevent double initialization if moved in DOM
      if (buttonContainer.children.length > 0) return;

      const activateTab = (targetLabel, emitEvent = true) => {
        let foundIndex = -1;
        panels.forEach((panel, i) => {
          const title = panel.getAttribute('data-label') || `Tab ${i + 1}`;
          if (title === targetLabel) foundIndex = i;
        });
        
        if (foundIndex === -1) return; // Tab not found in this group
        
        // Update buttons
        Array.from(buttonContainer.children).forEach((b, i) => {
          if (i === foundIndex) {
            b.classList.remove('border-transparent', 'text-slate-400');
            b.classList.add('border-indigo-600', 'text-indigo-700');
            b.setAttribute('aria-selected', 'true');
          } else {
            b.classList.remove('border-indigo-600', 'text-indigo-700');
            b.classList.add('border-transparent', 'text-slate-400');
            b.setAttribute('aria-selected', 'false');
          }
        });
        
        // Update panels
        panels.forEach((p, i) => {
          if (i === foundIndex) {
            p.classList.remove('hidden');
          } else {
            p.classList.add('hidden');
          }
        });

        // Persist preference and sync other tabs with the same syncKey
        if (emitEvent) {
          localStorage.setItem(storageKey, targetLabel);
          window.dispatchEvent(new CustomEvent('tab-sync', { 
            detail: { label: targetLabel, syncKey: syncKey } 
          }));
        }
      };

      // Initialize DOM structure
      panels.forEach((panel, i) => {
        const title = panel.getAttribute('data-label') || `Tab ${i + 1}`;
        const btn = document.createElement('button');
        
        // Start all as inactive styled (activateTab will fix this shortly)
        btn.className = `px-4 py-2 border-b-2 font-semibold text-sm whitespace-nowrap transition-colors duration-150 border-transparent text-slate-400 hover:text-slate-700 hover:border-slate-300`;
        btn.textContent = title;
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-selected', 'false');
        
        btn.addEventListener('click', () => {
          activateTab(title, true);
        });
        
        buttonContainer.appendChild(btn);
        panel.classList.add('hidden');
      });

      // Listen for global sync events from other tab groups
      window.addEventListener('tab-sync', (e: any) => {
        if (e.detail.syncKey === syncKey) {
          activateTab(e.detail.label, false);
        }
      });

      // On load, activate the preferred tab if it exists, otherwise default to the first tab
      const preferred = localStorage.getItem(storageKey);
      const firstTitle = panels[0]?.getAttribute('data-label') || 'Tab 1';
      
      const hasPreferred = panels.some(p => (p.getAttribute('data-label') || '') === preferred);
      activateTab(hasPreferred ? preferred : firstTitle, false);
    }
  }
  
  if (!customElements.get('custom-tabs')) {
    customElements.define('custom-tabs', TabsContainer);
  }
</script>

