---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const navItems = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/paths`, label: 'Learning Paths' },
  { href: `${base}/tutorials`, label: 'Tutorials' }
];
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-transform duration-300 ease-in-out border-b border-white/20 bg-white/70 backdrop-blur-md">
  <nav class="mx-auto flex h-12 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8" aria-label="Primary">
    <a href={`${base}/`} class="flex min-w-0 items-center gap-2 text-ink group">
      <span class="grid size-7 shrink-0 place-items-center rounded-md bg-gradient-to-br from-indigo-600 to-violet-700 text-[10px] font-900 text-white shadow-lg shadow-indigo-500/20 transition-transform duration-200 group-hover:scale-105">AA</span>
      <span class="block truncate text-sm font-900 tracking-tight text-indigo-600">Agent Academy</span>
    </a>
    
    <div class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <a class="rounded-md px-3 py-1.5 text-xs font-700 text-muted transition-all duration-200 hover:bg-indigo-50/80 hover:text-indigo-700" href={item.href}>
          {item.label}
        </a>
      ))}
    </div>

    <button id="nav-toggle" class="grid size-8 shrink-0 place-items-center rounded-md border border-border bg-white/50 text-muted transition-colors hover:border-indigo-500 hover:text-indigo-600 md:hidden" type="button" aria-controls="mobile-nav" aria-expanded="false">
      <span class="sr-only">Open navigation</span>
      <svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </nav>
  
  <div id="mobile-nav" class="hidden border-t border-border/60 bg-white/95 backdrop-blur-md px-4 py-3 md:hidden">
    {navItems.map((item) => (
      <a class="block rounded-md px-3 py-2 text-sm font-600 text-muted hover:bg-indigo-50 hover:text-indigo-700" href={item.href}>{item.label}</a>
    ))}
  </div>
</header>

<!-- Spacer to prevent content jump -->
<div class="h-12"></div>

<script>
  const header = document.querySelector('#main-header');
  const navToggle = document.querySelector('#nav-toggle');
  const mobileNav = document.querySelector('#mobile-nav');

  // Mobile menu toggle
  navToggle?.addEventListener('click', () => {
    const isOpen = navToggle.getAttribute('aria-expanded') === 'true';
    navToggle.setAttribute('aria-expanded', String(!isOpen));
    mobileNav?.classList.toggle('hidden');
  });

  // Auto-hide logic
  let lastScroll = 0;
  const threshold = 10;

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll <= 0) {
      header?.classList.remove('-translate-y-full');
      return;
    }
    
    if (Math.abs(currentScroll - lastScroll) < threshold) return;

    if (currentScroll > lastScroll && currentScroll > 60) {
      // Scrolling down
      header?.classList.add('-translate-y-full');
      mobileNav?.classList.add('hidden');
      navToggle?.setAttribute('aria-expanded', 'false');
    } else {
      // Scrolling up
      header?.classList.remove('-translate-y-full');
    }
    
    lastScroll = currentScroll;
  }, { passive: true });
</script>
