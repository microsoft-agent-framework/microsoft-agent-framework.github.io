---
import Navbar from '@/components/Navbar.astro';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  showFooter?: boolean;
}

const {
  title,
  description = 'Hands-on Agent Academy .NET tutorials for students and builders.',
  showFooter = true
} = Astro.props;
const pageTitle = title.includes('Agent Academy') ? title : `${title} | Agent Academy`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=JetBrains+Mono:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    <title>{pageTitle}</title>

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8VSWT1X5GP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body class="min-h-screen bg-surface text-slate-600 antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    {showFooter && (
      <footer class="border-t-2 border-border bg-white">
        <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-4 text-xs font-700 text-muted sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
          <p>Agent Academy</p>
          <div class="flex flex-wrap gap-3">
            <a class="transition-colors duration-150 hover:text-ink" href={`${import.meta.env.BASE_URL}/paths`}>Learning Paths</a>
            <a class="transition-colors duration-150 hover:text-ink" href={`${import.meta.env.BASE_URL}/tutorials`}>Tutorials</a>
          </div>
        </div>
      </footer>
    )}
    <script>
      import mermaid from 'mermaid';

      function showCopyToast(message) {
        const existing = document.querySelector('.copy-toast');
        existing?.remove();
        const toast = document.createElement('div');
        toast.className = 'copy-toast';
        toast.textContent = message;
        document.body.appendChild(toast);
        window.setTimeout(() => toast.remove(), 1600);
      }

      function enhanceCodeBlocks() {
        // Handle Mermaid Diagrams
        const mermaidBlocks = document.querySelectorAll('.tutorial-content pre');
        mermaidBlocks.forEach((pre) => {
          const code = pre.querySelector('code');
          const isMermaid = 
            pre.classList.contains('language-mermaid') || 
            code?.classList.contains('language-mermaid') ||
            pre.getAttribute('data-language') === 'mermaid';

          if (isMermaid && code) {
            const source = code.textContent;
            const container = document.createElement('div');
            const isWide = pre.closest('.mermaid-wide');
            container.className = `mermaid-container my-8 bg-white p-6 rounded-xl border border-slate-200 flex justify-center overflow-hidden ${isWide ? 'is-wide w-full' : ''}`;
            container.innerHTML = `<div class="mermaid w-full flex justify-center">${source}</div>`;
            pre.replaceWith(container);
          }
        });
        
        mermaid.initialize({ 
          startOnLoad: false, 
          theme: 'base',
          securityLevel: 'loose',
          useMaxWidth: true,
          themeVariables: {
            primaryColor: '#eef2ff',
            primaryTextColor: '#3730a3',
            primaryBorderColor: '#818cf8',
            lineColor: '#6366f1',
            secondaryColor: '#f8fafc',
            tertiaryColor: '#ffffff',
            mainBkg: '#eef2ff',
            nodeBorder: '#818cf8',
            clusterBkg: '#f8fafc',
            titleColor: '#1e1b4b',
            edgeLabelBackground: '#ffffff'
          }
        });
        mermaid.run();

        document.querySelectorAll('.tutorial-content pre').forEach((pre) => {
          if (pre.querySelector('.copy-code')) return;
          const code = pre.querySelector('code');
          if (!code || code.classList.contains('language-mermaid')) return;
          
          const rawLang = 
            pre.getAttribute('data-language') || 
            code.getAttribute('data-language') ||
            Array.from(pre.classList).find(c => c.startsWith('language-'))?.replace('language-', '') ||
            Array.from(code.classList).find(c => c.startsWith('language-'))?.replace('language-', '') ||
            Array.from(pre.classList).find(c => c.startsWith('lang-'))?.replace('lang-', '') ||
            'text';

          const label = rawLang.toLowerCase().replace('csharp', 'c#');

          const labelNode = document.createElement('span');
          labelNode.className = 'code-label';
          labelNode.textContent = label;

          const button = document.createElement('button');
          button.className = 'copy-code';
          button.type = 'button';
          button.textContent = 'Copy';
          button.addEventListener('click', async () => {
            await navigator.clipboard.writeText(code.textContent || '');
            button.textContent = 'Copied';
            showCopyToast('Code copied');

            // GA4: Track code copy event
            if (typeof gtag === 'function') {
              gtag('event', 'copy_code', {
                code_language: label,
                snippet_preview: (code.textContent || '').substring(0, 100),
                page_title: document.title
              });
            }

            window.setTimeout(() => {
              button.textContent = 'Copy';
            }, 1200);
          });

          pre.append(labelNode, button);
        });
      }

      enhanceCodeBlocks();
      document.addEventListener('astro:page-load', enhanceCodeBlocks);

      // ── GA4: Scroll depth tracking ──────────────────────────────
      function trackScrollDepth() {
        const milestones = [25, 50, 75, 100];
        const fired = new Set();

        function getScrollPercent() {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return 100;
          return Math.round((scrollTop / docHeight) * 100);
        }

        function checkMilestones() {
          const pct = getScrollPercent();
          for (const m of milestones) {
            if (pct >= m && !fired.has(m)) {
              fired.add(m);
              if (typeof gtag === 'function') {
                gtag('event', 'scroll_depth', {
                  depth_threshold: m,
                  page_title: document.title,
                  page_path: window.location.pathname
                });
              }
            }
          }
        }

        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              checkMilestones();
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });

        // Check on load in case page is short / already scrolled
        checkMilestones();
      }

      // ── GA4: Outbound link tracking ─────────────────────────────
      function trackOutboundLinks() {
        document.querySelectorAll('a[href^="http"]').forEach((link) => {
          const href = (link as HTMLAnchorElement).href;
          if (href && !href.includes(window.location.hostname)) {
            link.addEventListener('click', () => {
              if (typeof gtag === 'function') {
                gtag('event', 'outbound_click', {
                  link_url: href,
                  link_text: (link.textContent || '').trim().substring(0, 80),
                  page_title: document.title
                });
              }
            });
          }
        });
      }

      trackScrollDepth();
      trackOutboundLinks();
      document.addEventListener('astro:page-load', () => {
        trackScrollDepth();
        trackOutboundLinks();
      });
    </script>
  </body>
</html>
